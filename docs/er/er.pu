@startuml er
skinparam defaultFontName "Noto Sans CJK JP"

package "Authentication" {
  entity "User" as User {
    +id <<PK>>
    username <<UNIQUE>>
    email
    password
    name
  }
}

package "Dataset Domain" {
  
  entity "Dataset" as Dataset {
    +id <<PK>>
    owner <<FK>>
    name
    source_file
    status
    schema
    parse_result
    created_at
  }

  entity "DataPoint" as DataPoint {
    +id <<PK>>
    dataset <<FK>>
    raw_time
    time
    entity
    metric
    value
    order_index
    <<UNIQUE(dataset, entity, metric, raw_time)>>
  }

  User ||--o{ Dataset : owner
  Dataset ||--o{ DataPoint : dataset
}

note bottom of Dataset
status: UPLOADED / PROCESSING / PARSED / FAILED
schema and parse_result are JSONFields
end note

@enduml
